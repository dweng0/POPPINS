# BAADD — Environment Variables
#
# Copy this file to .env and fill in the keys you have.
# The agent picks the first available key in priority order:
#   ANTHROPIC_API_KEY > MOONSHOT_API_KEY > DASHSCOPE_API_KEY > OPENAI_API_KEY > GROQ_API_KEY > OLLAMA_HOST
#
# For GitHub Actions: add the relevant keys as repository secrets
# (Settings → Secrets and variables → Actions).

# ── Anthropic (Claude) — highest priority ──────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Kimi (Moonshot AI) ────────────────────────────────────────────────────
# https://platform.moonshot.cn/
# Default model: kimi-latest
# Other models:  moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
MOONSHOT_API_KEY=

# ── Alibaba / Qwen (DashScope) ────────────────────────────────────────────
# https://dashscope.aliyun.com/
# Default model: qwen-max
# Other models:  qwen-plus, qwen-turbo, qwen-long
DASHSCOPE_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────
# https://platform.openai.com/
# Default model: gpt-4o
OPENAI_API_KEY=

# ── Groq ──────────────────────────────────────────────────────────────────
# https://console.groq.com/
# Default model: llama-3.3-70b-versatile
# Other models:  mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=

# ── Ollama (local) ────────────────────────────────────────────────────────
# Only needed if Ollama is not on the default localhost:11434.
# The agent probes localhost automatically if no other key is set.
# Default model: llama3.2  (override with MODEL= below)
# OLLAMA_HOST=http://localhost:11434

# ── Model override (optional) ─────────────────────────────────────────────
# Override the default model for whichever provider is selected.
# Examples:
#   MODEL=claude-opus-4-6          (Anthropic)
#   MODEL=kimi-k2                  (Kimi)
#   MODEL=qwen-plus                (Alibaba)
#   MODEL=deepseek-r1-distill-llama-70b  (Groq)
#   MODEL=llama3.1:70b             (Ollama)
# MODEL=

# ── GitHub repo (used by evolve.sh) ──────────────────────────────────────
# Auto-detected from git remote. Override only if needed.
# REPO=owner/repo

# ── Session timeout in seconds (default: 3600) ────────────────────────────
# TIMEOUT=3600
